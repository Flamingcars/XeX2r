local PlayerTab = Window:Tab({Name = "Player"})
do
    PlayerTab:Divider({Text = "Local Player", Side = "Left"})

    PlayerTab:Button({
        Name = "Respawn",
        Side = "Left",
        Callback = function()
            if LocalPlayer.Character then LocalPlayer.Character:Destroy() end
        end
    })

    PlayerTab:Button({
        Name = "Rejoin Server",
        Side = "Left",
        Callback = function()
            XeX2r.Notify({Title = "Rejoining", Text = "Attempting to rejoin..."})
            local TeleportService = game:GetService("TeleportService")
            pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer) end)
        end
    })

    -- ============================
    -- CFrame Fly
    -- ============================
    PlayerTab:Divider({Text = "Flight", Side = "Left"})

    local flyEnabled = false
    local flySpeed = 50
    local flyConnection = nil

    -- Fly speed slider
    PlayerTab:Slider({
        Name = "Fly Speed",
        Side = "Left",
        Default = 50,
        Min = 10,
        Max = 300,
        Suffix = "s",
        Value = 50,
        Callback = function(Value)
            flySpeed = Value
        end
    })

    -- Fly toggle
    local FlyToggle = PlayerTab:Toggle({
        Name = "Toggle CFrame Fly (F)",
        Side = "Left",
        Value = false,
        Callback = function(Bool)
            flyEnabled = Bool
            local character = LocalPlayer.Character
            if not character then return end
            local hrp = character:FindFirstChild("HumanoidRootPart")
            local humanoid = character:FindFirstChildWhichIsA("Humanoid")
            if not hrp or not humanoid then return end

            if Bool then
                -- Enable fly
                humanoid.PlatformStand = true
                hrp.Anchored = false

                local camera = Workspace.CurrentCamera

                if flyConnection then flyConnection:Disconnect() end
                flyConnection = RunService.RenderStepped:Connect(function()
                    if not flyEnabled or not hrp or not hrp.Parent then
                        if flyConnection then
                            flyConnection:Disconnect()
                            flyConnection = nil
                        end
                        return
                    end

                    local moveDirection = Vector3.new()
                    local input = UserInputService

                    -- WASD movement relative to camera
                    if input:IsKeyDown(Enum.KeyCode.W) then
                        moveDirection = moveDirection + camera.CFrame.LookVector
                    end
                    if input:IsKeyDown(Enum.KeyCode.S) then
                        moveDirection = moveDirection - camera.CFrame.LookVector
                    end
                    if input:IsKeyDown(Enum.KeyCode.A) then
                        moveDirection = moveDirection - camera.CFrame.RightVector
                    end
                    if input:IsKeyDown(Enum.KeyCode.D) then
                        moveDirection = moveDirection + camera.CFrame.RightVector
                    end

                    -- Space = up, LeftShift = down
                    if input:IsKeyDown(Enum.KeyCode.Space) then
                        moveDirection = moveDirection + Vector3.new(0, 1, 0)
                    end
                    if input:IsKeyDown(Enum.KeyCode.LeftShift) then
                        moveDirection = moveDirection + Vector3.new(0, -1, 0)
                    end

                    if moveDirection.Magnitude > 0 then
                        moveDirection = moveDirection.Unit
                        local velocity = moveDirection * flySpeed
                        hrp.CFrame = hrp.CFrame + velocity
                    end

                    hrp.Anchored = false
                    humanoid.PlatformStand = true
                end)
            else
                -- Disable fly
                if flyConnection then
                    flyConnection:Disconnect()
                    flyConnection = nil
                end
                humanoid.PlatformStand = false
                if hrp then hrp.Anchored = false end
            end
        end
    })

    -- Keybind: F to toggle fly
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Enum.KeyCode.F then
            -- Toggle the fly state
            flyEnabled = not flyEnabled
            FlyToggle:Set(flyEnabled)
        end
    end)
end

