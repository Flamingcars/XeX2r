local selfChamConnection = nil

local function refreshSelfCham()
    local children = ESPGui:GetChildren()
    for i = 1, #children do
        if children[i].Name:match("^SelfCham_") then
            children[i]:Destroy()
        end
    end
    
    if not G.SelfCham then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local parts = {"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
    for namei = 1, #parts do
        local part = character:FindFirstChild(parts[namei])
        if part then
            local hl = GetOrCreateHighlight("SelfCham_" .. parts[namei], part)
            hl.FillColor = Color3.fromRGB(0, 255, 255)
            hl.OutlineColor = Color3.fromRGB(0, 255, 255)
            hl.FillTransparency = 0.4
            hl.OutlineTransparency = 0
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        end
    end
end

local function setupSelfCham()
    if selfChamConnection then
        selfChamConnection:Disconnect()
        selfChamConnection = nil
    end
    
    if G.SelfCham then
        refreshSelfCham()
        selfChamConnection = LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.5)
            refreshSelfCham()
        end)
    end
end

