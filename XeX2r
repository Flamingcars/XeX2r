                elseif v.Name == "FreezePod" then
                    tempPods[#tempPods + 1] = v
                elseif v.Name == "ExitDoor" then
                    tempExits[#tempExits + 1] = v
                end
            end

            local tagged = CollectionService:GetTagged("LOCKER")
            for i = 1, #tagged do
                tempLockers[#tempLockers + 1] = tagged[i]
            end
        else
            for i = 1, #XeX2r.Cache.Computers do tempComps[i] = XeX2r.Cache.Computers[i] end
            for i = 1, #XeX2r.Cache.Doors do tempDoors[i] = XeX2r.Cache.Doors[i] end
            for i = 1, #XeX2r.Cache.FreezePods do tempPods[i] = XeX2r.Cache.FreezePods[i] end
            for i = 1, #XeX2r.Cache.Lockers do tempLockers[i] = XeX2r.Cache.Lockers[i] end
            for i = 1, #XeX2r.Cache.Exits do tempExits[i] = XeX2r.Cache.Exits[i] end
        end

        XeX2r.Cache.Computers = tempComps
        XeX2r.Cache.Doors = tempDoors
        XeX2r.Cache.FreezePods = tempPods
        XeX2r.Cache.Lockers = tempLockers
        XeX2r.Cache.Exits = tempExits

        local espChildren = ESPGui:GetChildren()
        for i = 1, #espChildren do
            local obj = espChildren[i]
            if obj:IsA("Highlight") and (not obj.Adornee or not obj.Adornee.Parent) then
                obj:Destroy()
            end
        end

        task.wait(3)
    end
end)

