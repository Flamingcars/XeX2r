local FarmTab = Window:Tab({Name = "Auto Farm"})
do
    FarmTab:Divider({Text = "Farm Settings", Side = "Left"})

    local AutoFarmMode = FarmTab:Dropdown({
        Name = "Farm Mode",
        Side = "Left",
        Default = {"Pathfind (Undetected)"},
        List = {
            { Name = "Teleport", Mode = "Toggle", Value = false, Callback = function(Selected)
                G.FarmMode = "Teleport"
            end},
            { Name = "Pathfind (Undetected)", Mode = "Toggle", Value = false, Callback = function(Selected)
                G.FarmMode = "Pathfind (Undetected)"
            end}
        }
    })

    local AutoFarmToggle = FarmTab:Toggle({
        Name = "Auto Farm Computers",
        Side = "Left",
        Value = false,
        Callback = function(Bool)
            G.AutoFarm = Bool
        end
    })

    task.spawn(function()
        while true do
            task.wait(1)
            if not G.AutoFarm then continue end
            local targetComp = nil
            for i = 1, #XeX2r.Cache.Computers do
                local v = XeX2r.Cache.Computers[i]
                if v and v.Parent and v:FindFirstChild("Screen") then
                    if v.Screen.BrickColor == BrickColor.new("Bright blue") then
                        targetComp = v
                        break
                    end
                end
            end
            if targetComp then
                local triggerObj = targetComp:FindFirstChild("ComputerTrigger3") or targetComp:FindFirstChild("Trigger")
                local eventObj = triggerObj and triggerObj:FindFirstChild("Event")
                if eventObj then
                    local pos = triggerObj:GetPivot().Position
                    if G.FarmMode == "Teleport" then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 1, 0))
                    else
                        WalkTo(pos)
                    end
                    task.wait(0.5)
                    if targetComp.Screen.BrickColor == BrickColor.new("Bright blue") then
                        XeX2r.Notify({Title = "Auto Farm", Text = "Hacking..."})
                        RemoteEvent:FireServer("Input", "Trigger", true, eventObj)
                        task.wait(0.1)
                        RemoteEvent:FireServer("Input", "Action", true)
                        local timeout = 0
                        while targetComp:FindFirstChild("Screen") and targetComp.Screen.BrickColor == BrickColor.new("Bright blue") and timeout < 1500 do
                            RemoteEvent:FireServer("SetPlayerMinigameResult", true)
                            task.wait(0.1)
                            timeout = timeout + 0.1
                        end
                        RemoteEvent:FireServer("Input", "Action", false)
                        RemoteEvent:FireServer("Input", "Trigger", false, eventObj)
                        XeX2r.Notify({Title = "Auto Farm", Text = "Success!"})
                        task.wait(11)
                    end
                end
            end
        end
    end)
end

