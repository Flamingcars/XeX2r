-- CHAMS STATE (with per-cham colors)
-- ============================================================
local chamsState = {
    Players = false,
    Computers = false,
    PlayerColor = Color3.new(1, 1, 0),
    ComputerColor = Color3.new(0, 1, 0)
}

local chamsContainers = {
    Players = Instance.new("Folder"),
    Computers = Instance.new("Folder")
}
chamsContainers.Players.Name = "PlayerChams"
chamsContainers.Computers.Name = "ComputerChams"
chamsContainers.Players.Parent = ESPGui
chamsContainers.Computers.Parent = ESPGui

local function clearChams(folder)
    for _, obj in ipairs(folder:GetChildren()) do obj:Destroy() end
end

local function createHighlight(part, color, parent)
    if not part or not part:IsA("BasePart") then return end
    local hl = Instance.new("Highlight")
    hl.Name = "XeX2rChams"
    hl.Adornee = part
    hl.FillColor = color
    hl.OutlineColor = color
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = parent
    return hl
end

local function refreshPlayerChams()
    clearChams(chamsContainers.Players)
    if not chamsState.Players then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local character = player.Character
        if not character then continue end
        for _, partName in ipairs({"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}) do
            local part = character:FindFirstChild(partName)
            if part then createHighlight(part, chamsState.PlayerColor, chamsContainers.Players) end
        end
    end
end

local function refreshComputerChams()
    clearChams(chamsContainers.Computers)
    if not chamsState.Computers then return end
    for _, v in pairs(XeX2r.Cache.Computers) do
        if v and v.Parent then
            for _, child in ipairs(v:GetDescendants()) do
                if child:IsA("BasePart") then createHighlight(child, chamsState.ComputerColor, chamsContainers.Computers) end
            end
        end
    end
    local map = Workspace:FindFirstChild("Map")
    if map then
        local computersFolder = map:FindFirstChild("Computers")
        if computersFolder then
            for _, computer in ipairs(computersFolder:GetChildren()) do
                if computer:IsA("Model") then
                    for _, child in ipairs(computer:GetDescendants()) do
                        if child:IsA("BasePart") then createHighlight(child, chamsState.ComputerColor, chamsContainers.Computers) end
                    end
                end
            end
        end
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name == "Keyboard" or obj.Name == "Monitor") then
            createHighlight(obj, chamsState.ComputerColor, chamsContainers.Computers)
        end
    end
end

local function refreshAllChams()
    -- Player chams now refresh every frame to avoid stuck chams when players leave
    if chamsState.Players then
        clearChams(chamsContainers.Players)
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local character = player.Character
            if not character then continue end
            for _, partName in ipairs({"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}) do
                local part = character:FindFirstChild(partName)
                if part then createHighlight(part, chamsState.PlayerColor, chamsContainers.Players) end
            end
        end
    end
    -- Computer chams refresh every frame too
    if chamsState.Computers then
        clearChams(chamsContainers.Computers)
        for _, v in pairs(XeX2r.Cache.Computers) do
            if v and v.Parent then
                for _, child in ipairs(v:GetDescendants()) do
                    if child:IsA("BasePart") then createHighlight(child, chamsState.ComputerColor, chamsContainers.Computers) end
                end
            end
        end
        local map = Workspace:FindFirstChild("Map")
        if map then
            local computersFolder = map:FindFirstChild("Computers")
            if computersFolder then
                for _, computer in ipairs(computersFolder:GetChildren()) do
                    if computer:IsA("Model") then
                        for _, child in ipairs(computer:GetDescendants()) do
                            if child:IsA("BasePart") then createHighlight(child, chamsState.ComputerColor, chamsContainers.Computers) end
                        end
                    end
                end
            end
        end
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name == "Keyboard" or obj.Name == "Monitor") then
                createHighlight(obj, chamsState.ComputerColor, chamsContainers.Computers)
            end
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        refreshPlayerChams()
    end)
end)
Players.PlayerRemoving:Connect(function()
