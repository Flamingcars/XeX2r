XeX2r.Cache = { Computers = {}, Doors = {}, FreezePods = {}, Lockers = {}, Exits = {} }

task.spawn(function()
    local updateTick = 0
    while true do
        updateTick = updateTick + 1
        local tempComps, tempDoors, tempPods, tempLockers, tempExits = {}, {}, {}, {}, {}

        if updateTick % 2 == 1 then
            local descendants = Workspace:GetDescendants()
            for i = 1, #descendants do
                local v = descendants[i]
                if v.Name == "ComputerTable" and v:FindFirstChild("Screen") then
                    tempComps[#tempComps + 1] = v
